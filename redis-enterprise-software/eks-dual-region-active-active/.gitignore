.terraform.lock.hcl
terraform.tfstate
terraform.tfstate.backup
.terraform.tfstate.lock.info
*.tfstate
*.tfstate.*

# Terraform variable files (keep .example files)
terraform.tfvars

# Crash log files
crash.log
crash.*.log

# Exclude all .tfvars files except example
*.tfvars
!*.tfvars.example

# Ignore override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Ignore CLI configuration files
.terraformrc
terraform.rc

# macOS
.DS_Store
.AppleDouble
.LSOverride

# Temporary files
*.tmp
*.bak
*.swp
*~

# Log files
*.log

# IDE
.vscode/
.idea/
*.iml

