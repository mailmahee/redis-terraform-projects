#==============================================================================
# REDIS ENTERPRISE EKS ACTIVE-ACTIVE - EXAMPLE CONFIGURATION
#==============================================================================
# Copy this file to terraform.tfvars and customize for your deployment.
#
# This configuration deploys Redis Enterprise clusters across multiple
# AWS regions with Active-Active (CRDB) database replication using
# Kubernetes CRDs (RERC and REAADB).
#
# Architecture:
# - EKS cluster with Redis Enterprise operator per region
# - VPC peering mesh for cross-region communication
# - RERC (RedisEnterpriseRemoteCluster) for cluster discovery
# - REAADB (RedisEnterpriseActiveActiveDatabase) for Active-Active databases
#==============================================================================

#==============================================================================
# PROJECT IDENTIFICATION (Required)
#==============================================================================

owner       = "your-name"       # Your name/team for resource tagging
user_prefix = "yourprefix"      # Keep short (3-6 chars) to avoid name length limits
cluster_name = "redis-aa"       # Shared cluster name across all regions

# Optional project metadata
project     = "redis-enterprise-eks-aa"
environment = "dev"

#==============================================================================
# MULTI-REGION CONFIGURATION (Required for Active-Active)
#==============================================================================
# Define 2 regions for Active-Active deployment.
# Each region will have its own EKS cluster with Redis Enterprise.
# VPC CIDRs must not overlap between regions.

regions = {
  "us-west-2" = {
    vpc_cidr             = "10.0.0.0/16"
    public_subnet_cidrs  = ["10.0.1.0/24", "10.0.2.0/24", "10.0.3.0/24"]
    private_subnet_cidrs = ["10.0.4.0/24", "10.0.5.0/24", "10.0.6.0/24"]
    availability_zones   = []  # Empty = auto-select AZs in this region
    key_name             = "your-key-us-west-2"      # SSH key name in this region (optional)
    ssh_key_path         = "~/keys/your-key.pem"     # Path to SSH private key (optional)
  }
  "us-east-1" = {
    vpc_cidr             = "10.1.0.0/16"
    public_subnet_cidrs  = ["10.1.1.0/24", "10.1.2.0/24", "10.1.3.0/24"]
    private_subnet_cidrs = ["10.1.4.0/24", "10.1.5.0/24", "10.1.6.0/24"]
    availability_zones   = []  # Empty = auto-select AZs in this region
    key_name             = "your-key-us-east-1"      # SSH key name in this region (optional)
    ssh_key_path         = "~/keys/your-key.pem"     # Path to SSH private key (optional)
  }
}

#==============================================================================
# DNS CONFIGURATION (Required for Active-Active)
#==============================================================================
# Route53 hosted zone is required for Active-Active to work.
# The RERC and REAADB resources need DNS to discover remote clusters.

dns_hosted_zone_id = "ZXXXXXXXXXXXX"  # Your Route53 hosted zone ID
create_dns_records = true              # Create DNS records for API and DB FQDNs

# If create_dns_records = false, you must manually configure DNS or use
# the NLB DNS names directly (not recommended for Active-Active).

#==============================================================================
# REDIS ENTERPRISE CREDENTIALS (Required)
#==============================================================================

redis_cluster_username = "admin@example.com"
redis_cluster_password = "YourSecurePassword123"  # Alphanumeric only

#==============================================================================
# ACTIVE-ACTIVE DATABASE CONFIGURATION
#==============================================================================
# The REAADB is created in one region and synced by the operator to all others.

create_aa_database      = true
aa_database_name        = "my-aa-db"
aa_database_memory      = "500MB"
aa_database_shard_count = 1
aa_database_replication = true
aa_database_password    = ""           # Optional: leave empty for no password
aa_database_tls_mode    = "disabled"   # "disabled", "enabled", or "replica_ssl"

# Redis modules (optional - note: not all modules support Active-Active)
# aa_database_modules = [
#   { name = "RedisJSON" }
# ]

#==============================================================================
# EKS CLUSTER CONFIGURATION
#==============================================================================

kubernetes_version              = "1.33"
cluster_endpoint_public_access  = true
cluster_endpoint_private_access = true

#==============================================================================
# EKS NODE GROUP CONFIGURATION (per region)
#==============================================================================

node_instance_types = ["t3.xlarge"]  # Minimum for Redis Enterprise
node_desired_size   = 3              # Minimum 3 for HA
node_min_size       = 3
node_max_size       = 6
node_disk_size      = 100            # GB per node

#==============================================================================
# REDIS ENTERPRISE CLUSTER CONFIGURATION (per region)
#==============================================================================

redis_enterprise_namespace   = "redis-enterprise"
redis_operator_version       = "v7.4.6-2"
redis_cluster_nodes          = 3      # Minimum 3 for HA
redis_cluster_memory         = "4Gi"  # Memory per node
redis_cluster_storage_size   = "50Gi"
redis_cluster_storage_class  = "gp3"
redis_enterprise_version_tag = "7.4.6-22"

#==============================================================================
# REDIS FLEX (AUTO TIERING) - DISABLED FOR ACTIVE-ACTIVE
#==============================================================================
# IMPORTANT: Redis Flex is INCOMPATIBLE with Active-Active.
# This must remain false for multi-region deployments.

enable_redis_flex = false

#==============================================================================
# UI/SERVICE CONFIGURATION
#==============================================================================

redis_ui_service_type       = "ClusterIP"  # ClusterIP (internal) or LoadBalancer
ui_internal_lb_enabled      = false
redis_database_service_type = "ClusterIP"
redis_license_secret_name   = ""           # Optional: K8s secret with RE license

#==============================================================================
# INGRESS CONFIGURATION
#==============================================================================
# Ingress is automatically enabled for Active-Active deployments.
# These settings configure how ingress works.
#
# IMPORTANT: The "kubernetes.io/ingress.class" annotation is REQUIRED
# for the nginx ingress controller to pick up the ingress resources.
# Without it, the Redis API endpoints won't be accessible and RERC
# communication will fail.

redis_ingress_method = "ingress"  # "ingress" or "openShiftRoute"
redis_ingress_annotations = {
  "kubernetes.io/ingress.class"                 = "nginx"
  "nginx.ingress.kubernetes.io/ssl-passthrough" = "true"
}

#==============================================================================
# RESOURCE TAGGING
#==============================================================================

tags = {
  Terraform    = "true"
  Application  = "redis-enterprise"
  ActiveActive = "true"
}

#==============================================================================
# SINGLE-REGION CONFIGURATION EXAMPLE
#==============================================================================
# For a single-region deployment (no Active-Active), configure only one region:
#
# regions = {
#   "us-west-2" = {
#     vpc_cidr             = "10.0.0.0/16"
#     public_subnet_cidrs  = ["10.0.1.0/24", "10.0.2.0/24", "10.0.3.0/24"]
#     private_subnet_cidrs = ["10.0.4.0/24", "10.0.5.0/24", "10.0.6.0/24"]
#     availability_zones   = []
#     key_name             = ""
#     ssh_key_path         = ""
#   }
# }
#
# create_aa_database = false  # No AA database for single region

#==============================================================================
# DEPLOYMENT STEPS
#==============================================================================
#
# 1. Copy this file:
#    cp terraform.tfvars.example terraform.tfvars
#
# 2. Edit terraform.tfvars with your values:
#    - Set owner, user_prefix, cluster_name
#    - Configure regions with your VPC CIDRs
#    - Set dns_hosted_zone_id to your Route53 hosted zone
#    - Set redis_cluster_password
#
# 3. Deploy:
#    terraform init
#    terraform plan
#    terraform apply
#
# 4. Wait ~20-30 minutes for complete deployment (2 regions)
#
# 5. Verify deployment:
#    # Region 1
#    aws eks update-kubeconfig --region us-west-2 --name <prefix>-<cluster>-us-west-2
#    kubectl get rec,rerc,reaadb -n redis-enterprise
#
#    # Region 2
#    aws eks update-kubeconfig --region us-east-1 --name <prefix>-<cluster>-us-east-1
#    kubectl get rec,rerc,reaadb -n redis-enterprise
#
#==============================================================================
# ESTIMATED COSTS (2 regions)
#==============================================================================
#
# Per region:
# - EKS control plane: ~$73/month
# - 3x t3.xlarge nodes: ~$300/month
# - EBS gp3 storage: ~$25/month
# - Data transfer (cross-region): Variable
#
# Total for 2 regions: ~$800-1000/month for dev/test
#
# Remember to run `terraform destroy` when done testing!
#
#==============================================================================
